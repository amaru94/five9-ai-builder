    "dialer_optimization": {
      "id": "dialer_optimization",
      "name": "Dialer Optimization",
      "description": "Fix cases where the dialer is not reaching all leads: inspect lead demographic, dialing mode, campaign profile dial schedule/ASAP, and dispositions.",
