# Five9 AI Skill Engine - environment example
# Copy to .env and adjust.

APP_NAME=Five9 AI Skill Engine
DEBUG=false
LOG_LEVEL=INFO

# real = call external APIs; mocked = dry-run (no outbound HTTP to Five9)
EXECUTION_MODE=mocked

# Five9 endpoints (placeholders like {{ws_version}} resolved at runtime)
FIVE9_SOAP_BASE_URL=https://api.five9.com/wsadmin/{{ws_version}}/AdminWebService
FIVE9_REST_BASE_URL=https://api.five9.com
FIVE9_WEB2CAMPAIGN_BASE_URL=https://api.five9.com/web2campaign

# Domain DNC bulk (SOAP): Basic auth admin user; required for immediate add / remove
# FIVE9_SOAP_USERNAME=
# FIVE9_SOAP_PASSWORD=

# SQLite file for after-hours DNC add queue (created automatically)
# DNC_QUEUE_DB_PATH=data/dnc_queue.db

# Numbers per SOAP call (default 500)
# DNC_SOAP_CHUNK_SIZE=500

# Optional: require X-DNC-API-Key on /dnc/* (set same value in Next.js SKILL_ENGINE_DNC_KEY)
# DNC_API_KEY=

# Paths relative to backend project root
SKILLS_DIR=app/skills
REGISTRY_PATH=app/registry/skills.registry.json
PROMPTS_DIR=app/prompts

# Optional: LLM classifier URL (if set, used instead of mock router)
# LLM_ROUTER_URL=

# Min confidence to select skill (0-1)
ROUTING_CONFIDENCE_THRESHOLD=0.7
